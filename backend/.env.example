# =============================================================================
# AI Career Navigator - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values
# Required variables MUST be set for the app to start
# Optional variables enable additional features
# =============================================================================

# =============================================================================
# REQUIRED VARIABLES
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# -----------------------------------------------------------------------------
# Your Supabase project URL (e.g., https://xxxxx.supabase.co)
SUPABASE_URL=https://your-project.supabase.co

# Service role key - has full access to the database (backend only)
# WARNING: Never expose this in frontend code!
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# -----------------------------------------------------------------------------
# Google Gemini AI (Required)
# -----------------------------------------------------------------------------
# Get your API key from: https://aistudio.google.com/app/apikey
# This is used for:
# - Career analysis (GitHub + LeetCode + Resume → career paths)
# - Interview question generation
# - Answer evaluation and feedback
# - Coaching hints
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# JWT Configuration (Required for token expiry)
# -----------------------------------------------------------------------------
# Secret key for signing JWT tokens
# Generate a strong random key (e.g., use: python -c "import secrets; print(secrets.token_hex(32))")
# In production, use a proper secret management solution
JWT_SECRET_KEY=your-jwt-secret-key-min-32-chars-change-in-production


# =============================================================================
# OPTIONAL VARIABLES
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (Optional)
# -----------------------------------------------------------------------------
# Public anon key for frontend authentication
# Only needed if using Supabase Auth directly from the frontend
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -----------------------------------------------------------------------------
# GitHub API (Optional)
# -----------------------------------------------------------------------------
# GitHub Personal Access Token for higher rate limits
# Not required but recommended for production use
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# -----------------------------------------------------------------------------
# Job Search API (Optional)
# -----------------------------------------------------------------------------
# SerpAPI key for job search functionality
# Get from: https://serpapi.com/
# Without this, jobs page will fall back to mock data
SERPAPI_KEY=your_serpapi_key_here

# -----------------------------------------------------------------------------
# Email Configuration (Optional)
# -----------------------------------------------------------------------------
# Gmail address for sending weekly progress reports
# Note: Use an App Password, not your regular password
# Get app password at: https://support.google.com/accounts/answer/185833
GMAIL_USER=your-email@gmail.com

# 16-character app password (not your regular password)
GMAIL_APP_PASSWORD=your_16_char_app_password

# -----------------------------------------------------------------------------
# Server Configuration (Optional)
# -----------------------------------------------------------------------------
# Comma-separated list of allowed CORS origins
# Default: http://localhost:3000
# For production, list your frontend domain(s)
CORS_ORIGINS=http://localhost:3000


# =============================================================================
# CONFIGURATION NOTES
# =============================================================================
#
# To generate a .env file from this template:
#   cp .env.example .env
#
# Then edit .env and fill in your actual values.
#
# Required for basic operation:
#   - SUPABASE_URL
#   - SUPABASE_SERVICE_KEY
#   - GEMINI_API_KEY
#
# Optional but recommended:
#   - GITHUB_TOKEN (for higher GitHub API rate limits)
#   - SERPAPI_KEY (for real job search results)
#
# =============================================================================
